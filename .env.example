# HARetroPanel example configuration

# Required for real Home Assistant mode
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_token

# Dashboard settings
HARETROPANEL_PORT=8080
HARETROPANEL_LOG_LEVEL=haretropanel=info,tower_http=info
HARETROPANEL_LOG_DIR=./logs
HARETROPANEL_LOG_ROTATION=daily

# Dashboard entities
HARETROPANEL_SOLAR_ENTITY_ID=sensor.solar_power

# Solar buffer temp chart (optional - leave empty to disable)
HARETROPANEL_SOLAR_BUFFER_TOP_ENTITY_ID=sensor.solar_buffer_top
HARETROPANEL_SOLAR_BUFFER_BOTTOM_ENTITY_ID=sensor.solar_buffer_bottom
HARETROPANEL_SOLAR_FLOW_ENTITY_ID=sensor.solar_flow_temp
HARETROPANEL_SOLAR_RETURN_ENTITY_ID=sensor.solar_return_temp
HARETROPANEL_SOLAR_PUMP_ENTITY_ID=binary_sensor.solar_pump

# Go-E charger
HARETROPANEL_CHARGER_CURRENT_ENTITY_ID=sensor.goe_charger_current
HARETROPANEL_GOE_STATUS_ENTITY_ID=sensor.goe_status
HARETROPANEL_GOE_ENERGY_ENTITY_ID=sensor.goe_energy_since_plugged
HARETROPANEL_GOE_CAR_CONNECTED_ENTITY_ID=binary_sensor.goe_car_connected
HARETROPANEL_GOE_CHARGING_ENTITY_ID=binary_sensor.goe_charging

# Garage doors
HARETROPANEL_GARAGE_LEFT_ACTION_ENTITY_ID=cover.garage_garagentor_links_bewegen
HARETROPANEL_GARAGE_RIGHT_ACTION_ENTITY_ID=cover.garage_garagentor_rechts_bewegen
HARETROPANEL_GARAGE_LEFT_STATUS_ENTITY_ID=binary_sensor.garage_garage_links_offen
HARETROPANEL_GARAGE_RIGHT_STATUS_ENTITY_ID=binary_sensor.garage_garage_rechts_offen
HARETROPANEL_SOLAR_MAX_WATTS=9000
HARETROPANEL_SOLAR_HISTORY_MINUTES=60
HARETROPANEL_SOLAR_SAMPLE_SECS=60
HARETROPANEL_GOE_ENERGY_STABLE_SECS=60
HARETROPANEL_GOE_ENERGY_DELTA_KWH=0.02

# Demo mode (set to true to use sample data instead of HA)
HARETROPANEL_DEMO_MODE=false

# Cache TTLs (seconds)
HARETROPANEL_CACHE_TTL_DEFAULT_SECS=5
# HARETROPANEL_CACHE_TTL_LIGHT_SECS=5
# HARETROPANEL_CACHE_TTL_SWITCH_SECS=5
# HARETROPANEL_CACHE_TTL_SENSOR_SECS=5
# HARETROPANEL_CACHE_TTL_CLIMATE_SECS=5
