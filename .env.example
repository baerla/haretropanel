# HARetroPanel example configuration

# Required for real Home Assistant mode
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_token

# Dashboard settings
HARETROPANEL_PORT=8080
HARETROPANEL_LOG_LEVEL=haretropanel=info,tower_http=info
HARETROPANEL_LOG_DIR=./logs
HARETROPANEL_LOG_ROTATION=daily

# Dashboard entities
HARETROPANEL_SOLAR_ENTITY_ID=sensor.solar_power
HARETROPANEL_CHARGER_CURRENT_ENTITY_ID=sensor.goe_charger_current
HARETROPANEL_GARAGE_LEFT_ENTITY_ID=cover.garage_left
HARETROPANEL_GARAGE_RIGHT_ENTITY_ID=cover.garage_right
HARETROPANEL_SOLAR_MAX_WATTS=9000

# Demo mode (set to true to use sample data instead of HA)
HARETROPANEL_DEMO_MODE=false

# Cache TTLs (seconds)
HARETROPANEL_CACHE_TTL_DEFAULT_SECS=5
# HARETROPANEL_CACHE_TTL_LIGHT_SECS=5
# HARETROPANEL_CACHE_TTL_SWITCH_SECS=5
# HARETROPANEL_CACHE_TTL_SENSOR_SECS=5
# HARETROPANEL_CACHE_TTL_CLIMATE_SECS=5
